#!/bin/bash
# Pre-commit hook: run project safety checker before commit
# Blocks commit if: secrets, shell=True, os.system, hardcoded paths found
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
CHECKER="$PROJECT_DIR/scripts/check_project_safety.py"

echo "[pre-commit] Running safety check..."

if [ -f "$CHECKER" ]; then
    if ! python3 "$CHECKER" --dir "$PROJECT_DIR" 2>&1; then
        echo ""
        echo "[pre-commit] ❌ Commit blocked - safety violations detected"
        echo "[pre-commit] Fix issues above or use: git commit --no-verify (NOT recommended)"
        exit 1
    fi
    echo "[pre-commit] ✅ Safety check passed"
else
    echo "[pre-commit] ⚠️  check_project_safety.py not found, skipping"
fi
